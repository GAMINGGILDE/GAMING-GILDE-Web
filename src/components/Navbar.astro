<nav
  id="site-navbar"
  style="z-index: 99; transform: translateZ(0); transition: background 300ms ease, backdrop-filter 300ms ease"
  class="fixed w-full px-5 border-bottom top-0 start-0"
>
  <div class="max-w-(--breakpoint-xl) flex flex-wrap items-center justify-between mx-auto py-3">
    <a href="/" class="flex items-center">
      <img
        src="/logo.svg"
        width="75"
        height="75"
        class="w-[75px]"
        alt="gaming gilde logo"
        loading="eager"
      />
    </a>
    <button
      id="navbar-toggle"
      data-collapse-toggle="navbar-default"
      type="button"
      class="inline-flex items-center p-2 w-10 h-10 justify-center text-sm text-gray-500 hover:text-white transition ease-in-out duration-300 rounded-lg lg:hidden focus:outline-hidden focus:ring-2 focus:ring-gray-200 hover:bg-primary"
      aria-controls="navbar-default"
      aria-expanded="false"
      onclick="window.__ggToggleNavbar?.()"
    >
      <span class="sr-only">Open main menu</span>
      <svg
        class="w-5 h-5"
        aria-hidden="true"
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 17 14"
      >
        <path
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M1 1h15M1 7h15M1 13h15"></path>
      </svg>
    </button>
    <div class="hidden w-full lg:block lg:w-auto" id="navbar-default">
      <ul
        class="font-medium uppercase flex flex-col p-4 md:p-0 mt-4 rounded-lg lg:flex-row md:space-x-8 rtl:space-x-reverse lg:mt-0 lg:border-0"
      >
        <li>
          <a
            href="/"
            class="block py-2 px-3 text-primary rounded-sm hover:bg-transparent md:border-0 hover:text-primaryHover p-0 bg-transparent"
            aria-current="page">Startseite</a
          >
        </li>
        <li>
          <a
            href="/gameserver/"
            class="block py-2 px-3 text-primary rounded-sm hover:bg-transparent md:border-0 hover:text-primaryHover p-0 bg-transparent"
            >Gameserver</a
          >
        </li>
        <li>
          <a
            href="/event/"
            class="block py-2 px-3 text-primary rounded-sm hover:bg-transparent md:border-0 hover:text-primaryHover p-0 bg-transparent"
            >Event</a
          >
        </li>
        <li>
          <a
            href="/geschichte/"
            class="block py-2 px-3 text-primary rounded-sm hover:bg-transparent md:border-0 hover:text-primaryHover p-0 bg-transparent"
            >Geschichte</a
          >
        </li>
      </ul>
    </div>
  </div>
</nav>

<script is:inline>
  (() => {
    let isOpen = false;

    const updateNavbarState = () => {
      const nav = document.getElementById("site-navbar");
      const toggle = document.getElementById("navbar-toggle");
      const menu = document.getElementById("navbar-default");
      if (!nav || !toggle || !menu) return;

      nav.classList.toggle("navbar", isOpen || window.scrollY >= 100);
      menu.classList.toggle("hidden", !isOpen);
      menu.classList.toggle("block", isOpen);
      toggle.setAttribute("aria-expanded", String(isOpen));
    };

    window.__ggToggleNavbar = () => {
      isOpen = !isOpen;
      updateNavbarState();
    };

    const initNavbar = () => {
      const nav = document.getElementById("site-navbar");
      const toggle = document.getElementById("navbar-toggle");
      const menu = document.getElementById("navbar-default");
      if (!nav || !toggle || !menu || toggle.dataset.initialized === "true") return;

      toggle.dataset.initialized = "true";

      menu.querySelectorAll("a").forEach((link) => {
        link.addEventListener("click", () => {
          isOpen = false;
          updateNavbarState();
        });
      });

      window.addEventListener("scroll", updateNavbarState, { passive: true });
      updateNavbarState();
    };

    document.addEventListener("click", (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;
      if (!target.closest("#navbar-toggle")) return;

      const toggle = document.getElementById("navbar-toggle");
      if (toggle?.dataset.initialized === "true") return;

      isOpen = !isOpen;
      updateNavbarState();
    });

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initNavbar, { once: true });
    } else {
      initNavbar();
    }
  })();
</script>
