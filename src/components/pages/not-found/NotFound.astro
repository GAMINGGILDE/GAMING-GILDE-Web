    <section class="xl:px-0 px-5 md:px-10 mt-40 max-w-[1280px] mx-auto text-white">
      <div class="card-inner--blue p-6 lg:p-10">
        <p class="linear-text font-medium uppercase text-sm">GAMING GILDE</p>

        <div class="flex flex-row m-0 p-0 uppercase mt-3 flex-wrap gap-x-3">
          <h1 class="font-bold text-2xl lg:text-6xl tracking-widest m-0">Fehler</h1>
          <h1 class="linear-text font-bold text-2xl lg:text-6xl tracking-widest m-0">404</h1>
        </div>

        <h2 class="text-xl lg:text-3xl font-semibold mt-5">Diese Seite wurde nicht gefunden</h2>
        <p class="mt-4 font-light sub-text max-w-3xl">
          Die angeforderte Seite existiert nicht oder wurde verschoben. Nutze einen der folgenden
          Buttons, um zur Website zurueckzukehren.
        </p>

        <div class="flex flex-wrap gap-3 mt-7">
          <a
            href="/"
            class="inline-block py-2 px-3 text-white rounded-lg transition duration-300 md:border-0 p-0 bg-primary hover:bg-primaryHover"
          >
            Zur Startseite
          </a>
          <a
            href="/gameserver/"
            class="inline-block py-2 px-3 text-white rounded-lg transition duration-300 md:border-0 p-0 bg-primary hover:bg-primaryHover"
          >
            Zu den Gameservern
          </a>
        </div>
      </div>
    </section>
