---
import { Image } from "astro:assets";

interface Props {
  title: string;
  image: ImageMetadata;
  externalUrl?: string;
  colorVariant?: "blue" | "yellow" | "magenta";
  imageClassName?: string;
  imageLoading?: "eager" | "lazy";
  buttonClassName?: string;
  cornerLabel?: string;
  cornerLabelClassName?: string;
  copyValue?: string;
  modalId?: string;
}

const {
  title,
  image,
  externalUrl,
  colorVariant = "blue",
  imageClassName,
  imageLoading = "lazy",
  buttonClassName,
  cornerLabel,
  cornerLabelClassName,
  copyValue,
  modalId = `gameserver-${title.toLowerCase().replace(/[^a-z0-9]+/g, "-")}`,
} = Astro.props;

const cardHref = externalUrl ?? "#!";
const cardAttributes = externalUrl
  ? {
      href: cardHref,
      target: "_blank",
      rel: "noopener noreferrer",
    }
  : {
      href: cardHref,
      "data-gameserver-modal-trigger": modalId,
    };
---

<div class="my-5">
  <a {...cardAttributes}>
    <div class={`card-inner card-inner--${colorVariant} relative p-4 cursor-pointer text-white`}>
      {
        cornerLabel && (
          <span
            class={
              cornerLabelClassName ??
              "absolute top-3 right-3 rounded-full bg-primary/25 px-3 py-1 text-[10px] font-semibold uppercase tracking-wide text-white ring-1 ring-primary/60"
            }
          >
            {cornerLabel}
          </span>
        )
      }

      <div class="flex justify-between items-center mb-3 lg:hidden block">
        <h2 class="text-lg lg:text-xl font-semibold uppercase wrap-break-word">{title}</h2>
      </div>

      <div class="grid grid-cols-12">
        <div class="col-span-12 lg:col-span-6 mx-auto lg:hidden block mb-7">
          <Image
            src={image}
            alt="gameserver preview"
            class={imageClassName ?? "w-[20rem] object-contain rounded-lg"}
            width="640"
            loading={imageLoading}
          />
        </div>

        <div class="col-span-12 lg:col-span-6 text-xm">
          <div class="flex justify-between items-center mb-3 lg:block hidden">
            <h2 class="text-lg lg:text-xl font-semibold uppercase wrap-break-word">{title}</h2>
          </div>

          <slot name="cardText" />

          <div class="flex mt-3">
            <div
              data-copy-value={copyValue}
              class={
                buttonClassName ??
                "bg-primary px-5 text-center py-0.5 rounded-full flex items-center"
              }
            >
              <slot name="button" />
            </div>
          </div>
        </div>

        <div class="col-span-12 lg:col-span-6 mx-auto lg:block hidden my-auto">
          <Image
            src={image}
            alt="gameserver preview"
            class={imageClassName ?? "w-70 object-contain rounded-lg"}
            width="640"
            loading={imageLoading}
          />
        </div>
      </div>
    </div>
  </a>
</div>

{
  !externalUrl && (
    <div
      id={modalId}
      data-gameserver-modal
      data-modal-backdrop="static"
      tabindex="-1"
      aria-hidden="true"
      style="z-index: 9999"
      class="fixed inset-0 z-50 hidden justify-center items-center w-full h-full bg-opacity-50 backdrop-blur-md"
    >
      <div class="relative modal overflow-auto p-4 w-full max-w-2xl max-h-full rounded-lg shadow-xs">
        <div class="flex items-center justify-between p-4 md:p-5 border-b rounded-t dark:border-gray-600 border-gray-200">
          <h3 class="text-xl font-semibold text-white">{title}</h3>
          <button
            type="button"
            class="text-gray-400 bg-transparent hover:bg-gray-200 hover:text-gray-900 rounded-lg text-sm w-8 h-8 ms-auto inline-flex justify-center items-center"
            data-gameserver-modal-close
          >
            <svg
              class="w-3 h-3"
              aria-hidden="true"
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 14 14"
            >
              <path
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"
              />
            </svg>
            <span class="sr-only">Close modal</span>
          </button>
        </div>
        <div class="p-4 md:p-5 space-y-4">
          <slot />
        </div>
      </div>
    </div>
  )
}
